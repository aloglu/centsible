DISCORD_WEBHOOK=
DISCORD_PROXY_BASE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: enables unattended encrypted backups after restart without storing the
# derived backup key on disk. Use the same value you set as the backup password.
BACKUP_PASSWORD=
# Optional: custom runtime data directory. The Docker image defaults to /app/data.
DATA_DIR=
# Optional: comma-separated list. Leave empty to allow all origins.
# Example: ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.50:3000
ALLOWED_ORIGINS=
FETCH_ALLOWED_HOSTS=
